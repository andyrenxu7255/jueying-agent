{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["server", "database", "redis", "workflow", "executor", "retrieval", "logging"],
  "properties": {
    "server": {
      "type": "object",
      "required": ["port", "host"],
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "host": { "type": "string" },
        "graceful_shutdown_timeout_ms": { "type": "integer", "minimum": 1000 }
      }
    },
    "database": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string" },
        "pool_size": { "type": "integer", "minimum": 1, "maximum": 100 },
        "connection_timeout_ms": { "type": "integer", "minimum": 100 },
        "statement_timeout_ms": { "type": "integer", "minimum": 100 },
        "ssl": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "key_prefix": { "type": "string" },
        "prefix": { "type": "string" },
        "max_retries": { "type": "integer" },
        "retry_delay_ms": { "type": "integer" },
        "retry_strategy": { "type": "object" }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "backend": { "type": "string", "enum": ["localfs", "minio", "s3"] },
        "local_root": { "type": "string" },
        "endpoint": { "type": "string" },
        "bucket": { "type": "string" },
        "access_key": { "type": "string" },
        "secret_key": { "type": "string" },
        "region": { "type": "string" },
        "use_ssl": { "type": "boolean" }
      }
    },
    "workflow": {
      "type": "object",
      "properties": {
        "max_concurrent": { "type": "integer", "minimum": 1 },
        "default_timeout_sec": { "type": "integer", "minimum": 30 },
        "checkpoint_interval_sec": { "type": "integer", "minimum": 10 },
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 10 },
        "max_repairs": { "type": "integer", "minimum": 0, "maximum": 20 },
        "poll_interval_sec": { "type": "integer", "minimum": 1 },
        "plan_budget_sec": { "type": "integer", "minimum": 60 },
        "supervisor_budget_sec": { "type": "integer", "minimum": 60 },
        "poll_max_iterations": { "type": "integer", "minimum": 1 }
      }
    },
    "llm": {
      "type": "object",
      "properties": {
        "primary_model": { "type": "string" },
        "fallback_model": { "type": "string" },
        "fallback_models": { "type": "array", "items": { "type": "string" } },
        "litellm_url": { "type": "string" },
        "litellm_master_key": { "type": "string" },
        "litellm_api_key": { "type": "string" },
        "default_timeout_ms": { "type": "integer" },
        "planner_model": { "type": "string" },
        "executor_model": { "type": "string" },
        "minimax_api_key": { "type": "string" },
        "dashscope_api_key": { "type": "string" },
        "minimax": {
          "type": "object",
          "properties": {
            "api_base": { "type": "string" },
            "api_key": { "type": "string" },
            "model": { "type": "string" },
            "max_tokens": { "type": "integer" }
          }
        },
        "dashscope": {
          "type": "object",
          "properties": {
            "api_base": { "type": "string" },
            "api_key": { "type": "string" },
            "models": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "executor": {
      "type": "object",
      "properties": {
        "max_concurrent_sessions": { "type": "integer", "minimum": 1 },
        "worktree_base": { "type": "string" },
        "worktree_root": { "type": "string" },
        "default_timeout_sec": { "type": "integer", "minimum": 30 }
      }
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "max_candidates": { "type": "integer", "minimum": 1, "maximum": 200 },
        "default_intent": { "type": "string" },
        "enable_graph": { "type": "boolean" },
        "max_graph_hops": { "type": "integer", "minimum": 1, "maximum": 5 },
        "enable_rerank": { "type": "boolean" },
        "embedding_mode": { "type": "string", "enum": ["deterministic", "provider"] },
        "rerank_mode": { "type": "string", "enum": ["deterministic", "provider"] },
        "embedding_provider_url": { "type": "string" },
        "embedding_provider_api_key": { "type": "string" },
        "embedding_provider_model": { "type": "string" },
        "embedding_provider_timeout_ms": { "type": "integer", "minimum": 1000 },
        "rerank_provider_url": { "type": "string" },
        "rerank_provider_api_key": { "type": "string" },
        "rerank_provider_model": { "type": "string" },
        "rerank_provider_timeout_ms": { "type": "integer", "minimum": 1000 }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "format": { "type": "string", "enum": ["json", "text"] },
        "output": { "type": "string", "enum": ["stdout", "file"] }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "tracing": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "sample_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "feishu": {
      "type": "object",
      "properties": {
        "app_id": { "type": "string" },
        "app_secret": { "type": "string" },
        "verification_token": { "type": "string" },
        "encrypt_key": { "type": "string" },
        "bot_name": { "type": "string" }
      }
    },
    "cors": {
      "type": "object",
      "properties": {
        "origins": { "type": "array", "items": { "type": "string" } },
        "allow_credentials": { "type": "boolean" }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "jwt_secret": { "type": "string" },
        "session_secret": { "type": "string" },
        "internal_auth_secret": { "type": "string" },
        "admin_password": { "type": "string" }
      }
    }
  }
}