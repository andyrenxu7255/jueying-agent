# ============================================================
# Agent Harness 环境变量配置模板
# 
# ⚠️ 安全警告 (SECURITY WARNING):
#   1. 所有 <...> 占位符必须在部署前替换为真实值
#   2. 生产环境必须使用 docker-compose.prod.yml 覆盖文件
#      docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#   3. 生产环境必须更改所有默认密码
#   4. 生产环境 NODE_ENV=production 时会强制校验非默认密码
#   5. 切勿将包含真实凭据的 .env 文件提交到版本控制
# ============================================================

NODE_ENV=development

# --- 数据库 ---
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>
POSTGRES_USER=<DB_USER>
POSTGRES_PASSWORD=<DB_PASSWORD>
POSTGRES_DB=<DB_NAME>

# --- Redis ---
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379
REDIS_PASSWORD=<REDIS_PASSWORD>

# --- MinIO 对象存储 ---
MINIO_ROOT_USER=<MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<MINIO_ADMIN_PASSWORD>
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_ENDPOINT=localhost:9000

# --- LLM Gateway (LiteLLM) ---
LITELLM_MASTER_KEY=<LITELLM_MASTER_KEY>
MINIMAX_API_KEY=<MINIMAX_API_KEY>
DASHSCOPE_API_KEY=<DASHSCOPE_API_KEY>
LITELLM_DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@postgres:5432/litellm

# --- Embedding / Rerank ---
EMBEDDING_PROVIDER_API_KEY=<EMBEDDING_API_KEY>
EMBEDDING_PROVIDER_URL=https://api.siliconflow.cn/v1
EMBEDDING_PROVIDER_MODEL=Qwen/Qwen3-Embedding-8B

RERANK_PROVIDER_API_KEY=<RERANK_API_KEY>
RERANK_PROVIDER_URL=https://api.siliconflow.cn/v1
RERANK_PROVIDER_MODEL=Qwen/Qwen3-Reranker-8B

# --- 飞书渠道 ---
FEISHU_APP_ID=<FEISHU_APP_ID>
FEISHU_APP_SECRET=<FEISHU_APP_SECRET>
FEISHU_DOMAIN=feishu
FEISHU_SIGNING_SECRET=<FEISHU_SIGNING_SECRET>

# --- 企业微信渠道 ---
WECOM_TOKEN=<WECOM_TOKEN>
WECOM_CORP_ID=<WECOM_CORP_ID>
WECOM_CORP_SECRET=<WECOM_CORP_SECRET>
WECOM_AGENT_ID=<WECOM_AGENT_ID>
WECOM_ENCODING_AES_KEY=<WECOM_ENCODING_AES_KEY>

# --- 服务地址 ---
LITELLM_URL=http://localhost:4000
WORKFLOW_URL=http://localhost:3001
EXECUTOR_URL=http://localhost:3002
FACT_RETRIEVAL_URL=http://localhost:3004
GATEWAY_URL=http://localhost:3000
HERMES_URL=http://localhost:3005
SKILL_LIBRARY_URL=http://localhost:3007
RESOURCE_SCHEDULER_URL=http://localhost:3008
MOBILE_APP_URL=http://localhost:3009

# --- 可观测性 ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- ClickHouse (SigNoz 存储) ---
CLICKHOUSE_USER=<CLICKHOUSE_USER>
CLICKHOUSE_PASSWORD=<CLICKHOUSE_PASSWORD>

# --- Web ---
CORS_ORIGINS=http://localhost:3003
ADMIN_PASSWORD=<ADMIN_PASSWORD>

# --- 其他 ---
SERVER_PORT=3000
LOG_LEVEL=debug
